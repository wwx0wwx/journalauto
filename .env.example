# Copy this file to .env and fill in real values.
# Example:
#   cp .env.example .env

OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions # 必须包含类似 /v1/chat/completions 的完整路径
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini  # 用于摘要、润色等低要求任务，留空则与 OPENAI_MODEL 相同

ENGINE_ROOT=/opt/blog-src
BLOG_OUTPUT_DIR=/var/www/example.com
# PERSONA_MD=/opt/blog-src/automation/persona.md  # 默认值，换角色时改此路径
